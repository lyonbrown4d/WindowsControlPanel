<UserControl x:Class="WindowsControlPanel.Views.SecurityVirtualizationPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:mvvm="http://prismlibrary.com/"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             mvvm:ViewModelLocator.AutoWireViewModel="True"
             mc:Ignorable="d"
             d:DesignHeight="620"
             d:DesignWidth="900">
    <Grid Margin="{StaticResource AppPageMargin}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Style="{StaticResource AppEyebrowTextStyle}" Text="SECURITY" />
                <TextBlock Margin="0,5,0,0" Style="{StaticResource AppPageTitleTextStyle}" Text="安全与虚拟化" />
                <TextBlock Margin="0,7,0,0"
                           Style="{StaticResource AppBodyTextStyle}"
                           Text="统一管理 VBS、Hyper-V、WSL 相关能力。高风险操作会先确认，并通常需要管理员权限。" />
            </StackPanel>
            <ui:Button Grid.Column="1"
                       Width="124"
                       Height="36"
                       Margin="18,0,0,0"
                       VerticalAlignment="Center"
                       Appearance="Secondary"
                       Command="{Binding RefreshCommand}"
                       Content="刷新状态" />
        </Grid>

        <Border Grid.Row="1"
                Margin="0,0,0,14"
                Padding="14"
                CornerRadius="8"
                Background="{DynamicResource AppSurfaceElevatedBrush}"
                BorderBrush="{DynamicResource AppStrokeBrush}"
                BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <UniformGrid Grid.Column="0" Columns="2">
                    <StackPanel Margin="0,0,16,0">
                        <TextBlock Style="{StaticResource AppSmallLabelTextStyle}" Text="VBS" />
                        <TextBlock Margin="0,5,0,0" FontSize="13" Text="{Binding VbsStatus}" TextWrapping="Wrap" />
                    </StackPanel>
                    <StackPanel Margin="0,0,16,0">
                        <TextBlock Style="{StaticResource AppSmallLabelTextStyle}" Text="虚拟化" />
                        <TextBlock Margin="0,5,0,0" FontSize="13" Text="{Binding VirtualizationStatus}" TextWrapping="Wrap" />
                    </StackPanel>
                    <StackPanel Margin="0,12,16,0">
                        <TextBlock Style="{StaticResource AppSmallLabelTextStyle}" Text="权限" />
                        <TextBlock Margin="0,5,0,0" FontSize="13" Text="{Binding AdminStatus}" TextWrapping="Wrap" />
                    </StackPanel>
                    <StackPanel Margin="0,12,16,0">
                        <TextBlock Style="{StaticResource AppSmallLabelTextStyle}" Text="重启提示" />
                        <TextBlock Margin="0,5,0,0" FontSize="13" Text="{Binding RestartHint}" TextWrapping="Wrap" />
                    </StackPanel>
                </UniformGrid>

                <StackPanel Grid.Column="1"
                            MinWidth="220"
                            Margin="18,0,0,0"
                            VerticalAlignment="Center">
                    <CheckBox IsChecked="{Binding AutoRebootAfterApply}"
                              Content="应用后自动重启（5 秒）" />
                    <ui:Button Margin="0,10,0,0"
                               Height="34"
                               Appearance="Secondary"
                               Command="{Binding RelaunchAsAdminCommand}"
                               Content="以管理员重新启动" />
                </StackPanel>
            </Grid>
        </Border>

        <UniformGrid Grid.Row="2" Columns="2" Margin="0,0,0,14">
            <Border Margin="0,0,7,0"
                    Padding="14"
                    CornerRadius="8"
                    Background="{DynamicResource AppSurfaceBrush}"
                    BorderBrush="{DynamicResource AppStrokeBrush}"
                    BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Width="36"
                            Height="36"
                            Margin="0,0,12,0"
                            CornerRadius="9"
                            Background="{DynamicResource AppAccentSoftBrush}"
                            BorderBrush="{DynamicResource AppStrokeBrush}"
                            BorderThickness="1">
                        <ui:SymbolIcon Width="19" Height="19" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource AppAccentBrush}" Symbol="Code24" />
                    </Border>
                    <StackPanel Grid.Column="1">
                        <TextBlock Style="{StaticResource AppSectionTitleTextStyle}" Text="开发模式预设" />
                        <TextBlock Margin="0,6,0,12" Style="{StaticResource AppBodyTextStyle}" Text="启用 Hyper-V、WSL、VBS 等能力。适合开发、容器和虚拟化环境。" />
                        <ui:Button Width="150" HorizontalAlignment="Left" Appearance="Primary" Command="{Binding EnableDevModeCommand}" Content="应用开发模式" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border Margin="7,0,0,0"
                    Padding="14"
                    CornerRadius="8"
                    Background="{DynamicResource AppSurfaceBrush}"
                    BorderBrush="{DynamicResource AppStrokeBrush}"
                    BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Width="36"
                            Height="36"
                            Margin="0,0,12,0"
                            CornerRadius="9"
                            Background="{DynamicResource AppDangerSoftBrush}"
                            BorderBrush="{DynamicResource AppStrokeBrush}"
                            BorderThickness="1">
                        <ui:SymbolIcon Width="19" Height="19" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource AppDangerBrush}" Symbol="Games24" />
                    </Border>
                    <StackPanel Grid.Column="1">
                        <TextBlock Style="{StaticResource AppSectionTitleTextStyle}" Text="游戏模式预设" />
                        <TextBlock Margin="0,6,0,12" Style="{StaticResource AppBodyTextStyle}" Text="关闭虚拟化链路并优先兼容游戏性能。适合纯娱乐场景。" />
                        <ui:Button Width="150" HorizontalAlignment="Left" Appearance="Danger" Command="{Binding EnableGameModeCommand}" Content="应用游戏模式" />
                    </StackPanel>
                </Grid>
            </Border>
        </UniformGrid>

        <Border Grid.Row="3"
                Padding="12"
                CornerRadius="8"
                Background="{DynamicResource AppSurfaceBrush}"
                BorderBrush="{DynamicResource AppStrokeBrush}"
                BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Style="{StaticResource AppSectionTitleTextStyle}" Text="执行与审计" />
                    <ui:Button Grid.Column="1" Width="104" Height="32" Appearance="Secondary" Command="{Binding BackToHomeCommand}" Content="返回首页" />
                </Grid>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Style="{StaticResource AppSmallLabelTextStyle}" Text="执行日志" />
                    <TextBlock Grid.Row="0" Grid.Column="1" Margin="12,0,0,0" Style="{StaticResource AppSmallLabelTextStyle}" Text="最近审计" />
                    <TextBox Grid.Row="1" Margin="0,7,6,0" Style="{StaticResource AppLogTextBoxStyle}" Text="{Binding ExecutionLog, Mode=OneWay}" />
                    <TextBox Grid.Row="1" Grid.Column="1" Margin="6,7,0,0" Style="{StaticResource AppLogTextBoxStyle}" Text="{Binding AuditSummary, Mode=OneWay}" />
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
