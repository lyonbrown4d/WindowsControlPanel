<UserControl x:Class="WindowsControlPanel.Views.SystemToolkitPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:mvvm="http://prismlibrary.com/"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             mvvm:ViewModelLocator.AutoWireViewModel="True"
             mc:Ignorable="d"
             d:DesignHeight="680"
             d:DesignWidth="920">
    <Grid Margin="{StaticResource AppPageMargin}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="0.34*" MinHeight="140" MaxHeight="190" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Style="{StaticResource AppEyebrowTextStyle}" Text="TOOLKIT" />
                <TextBlock Margin="0,5,0,0" Style="{StaticResource AppPageTitleTextStyle}" Text="{Binding Title}" />
                <TextBlock Margin="0,7,0,0" Style="{StaticResource AppBodyTextStyle}" Text="{Binding Description}" />
            </StackPanel>
            <ui:Button Grid.Column="1" Width="124" Height="36" Margin="18,0,0,0" VerticalAlignment="Center" Appearance="Secondary" Command="{Binding RefreshStatusCommand}" Content="刷新状态">
                <ui:Button.Icon>
                    <ui:SymbolIcon Symbol="ArrowClockwise24" />
                </ui:Button.Icon>
            </ui:Button>
        </Grid>

        <Border Grid.Row="1"
                Margin="0,0,0,14"
                Padding="14"
                CornerRadius="8"
                Background="{DynamicResource GlassPanelElevatedBrush}"
                BorderBrush="{DynamicResource AppStrokeBrush}"
                BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Width="34" Height="34" Margin="0,0,12,0" CornerRadius="8" Background="{DynamicResource AppAccentSoftBrush}" BorderBrush="{DynamicResource AppStrokeBrush}" BorderThickness="1">
                    <ui:SymbolIcon Width="18" Height="18" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource AppAccentBrush}" Symbol="Delete24" />
                </Border>
                <StackPanel Grid.Column="1">
                    <TextBlock Style="{StaticResource AppSmallLabelTextStyle}" Text="状态摘要" />
                    <TextBlock Margin="0,5,0,0" FontSize="13" Text="{Binding FeatureStateSummary}" TextWrapping="Wrap" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Margin="0,0,7,0"
                    Padding="14"
                    CornerRadius="8"
                    Background="{DynamicResource GlassPanelBrush}"
                    BorderBrush="{DynamicResource AppStrokeBrush}"
                    BorderThickness="1">
                <StackPanel>
                    <TextBlock Style="{StaticResource AppSectionTitleTextStyle}" Text="可选功能开关" />
                    <TextBlock Margin="0,6,0,14" Style="{StaticResource AppBodyTextStyle}" Text="统一管理 Hyper-V / WSL / Sandbox，执行后通常需要重启。" />

                    <TextBlock Style="{StaticResource AppSmallLabelTextStyle}" Text="Hyper-V" />
                    <WrapPanel Margin="0,8,0,12">
                        <ui:Button Width="112" Margin="0,0,8,8" Appearance="Primary" Command="{Binding EnableHyperVCommand}" Content="启用" />
                        <ui:Button Width="112" Margin="0,0,8,8" Appearance="Secondary" Command="{Binding DisableHyperVCommand}" Content="禁用" />
                    </WrapPanel>

                    <TextBlock Style="{StaticResource AppSmallLabelTextStyle}" Text="WSL" />
                    <WrapPanel Margin="0,8,0,12">
                        <ui:Button Width="112" Margin="0,0,8,8" Appearance="Primary" Command="{Binding EnableWslCommand}" Content="启用" />
                        <ui:Button Width="112" Margin="0,0,8,8" Appearance="Secondary" Command="{Binding DisableWslCommand}" Content="禁用" />
                    </WrapPanel>

                    <TextBlock Style="{StaticResource AppSmallLabelTextStyle}" Text="Windows Sandbox" />
                    <WrapPanel Margin="0,8,0,0">
                        <ui:Button Width="112" Margin="0,0,8,8" Appearance="Primary" Command="{Binding EnableSandboxCommand}" Content="启用" />
                        <ui:Button Width="112" Margin="0,0,8,8" Appearance="Secondary" Command="{Binding DisableSandboxCommand}" Content="禁用" />
                        <ui:Button Width="150" Margin="0,0,8,8" Appearance="Secondary" Command="{Binding OpenOptionalFeaturesCommand}" Content="打开功能管理器">
                            <ui:Button.Icon>
                                <ui:SymbolIcon Symbol="Settings24" />
                            </ui:Button.Icon>
                        </ui:Button>
                    </WrapPanel>
                </StackPanel>
            </Border>

            <Border Grid.Column="1"
                    Margin="7,0,0,0"
                    Padding="14"
                    CornerRadius="8"
                    Background="{DynamicResource GlassPanelBrush}"
                    BorderBrush="{DynamicResource AppStrokeBrush}"
                    BorderThickness="1">
                <StackPanel>
                    <TextBlock Style="{StaticResource AppSectionTitleTextStyle}" Text="网络与维护入口" />
                    <TextBlock Margin="0,6,0,14" Style="{StaticResource AppBodyTextStyle}" Text="把深层设置与诊断命令整合成可回溯的按钮动作。" />

                    <TextBlock Style="{StaticResource AppSmallLabelTextStyle}" Text="设置入口" />
                    <WrapPanel Margin="0,8,0,12">
                        <ui:Button Width="150" Margin="0,0,8,8" Appearance="Secondary" Command="{Binding OpenDnsSettingsCommand}" Content="DNS 高级设置">
                            <ui:Button.Icon>
                                <ui:SymbolIcon Symbol="Globe24" />
                            </ui:Button.Icon>
                        </ui:Button>
                        <ui:Button Width="160" Margin="0,0,8,8" Appearance="Secondary" Command="{Binding OpenDeliveryOptimizationCommand}" Content="传递优化设置">
                            <ui:Button.Icon>
                                <ui:SymbolIcon Symbol="Rocket24" />
                            </ui:Button.Icon>
                        </ui:Button>
                        <ui:Button Width="150" Margin="0,0,8,8" Appearance="Secondary" Command="{Binding OpenStorageSenseCommand}" Content="存储感知">
                            <ui:Button.Icon>
                                <ui:SymbolIcon Symbol="Delete24" />
                            </ui:Button.Icon>
                        </ui:Button>
                    </WrapPanel>

                    <TextBlock Style="{StaticResource AppSmallLabelTextStyle}" Text="诊断报告" />
                    <WrapPanel Margin="0,8,0,0">
                        <ui:Button Width="150" Margin="0,0,8,8" Appearance="Secondary" Command="{Binding QueryStartupProgramsCommand}" Content="扫描启动项">
                            <ui:Button.Icon>
                                <ui:SymbolIcon Symbol="Rocket24" />
                            </ui:Button.Icon>
                        </ui:Button>
                        <ui:Button Width="150" Margin="0,0,8,8" Appearance="Secondary" Command="{Binding GenerateEnergyReportCommand}" Content="能耗报告">
                            <ui:Button.Icon>
                                <ui:SymbolIcon Symbol="Desktop24" />
                            </ui:Button.Icon>
                        </ui:Button>
                        <ui:Button Width="150" Margin="0,0,8,8" Appearance="Secondary" Command="{Binding GenerateBatteryReportCommand}" Content="电池报告">
                            <ui:Button.Icon>
                                <ui:SymbolIcon Symbol="Desktop24" />
                            </ui:Button.Icon>
                        </ui:Button>
                    </WrapPanel>
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Row="3"
                Margin="0,14,0,0"
                Padding="12"
                CornerRadius="8"
                Background="{DynamicResource GlassPanelBrush}"
                BorderBrush="{DynamicResource AppStrokeBrush}"
                BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid Grid.Row="0" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Style="{StaticResource AppSectionTitleTextStyle}" Text="执行日志" />
                </Grid>
                <TextBox Grid.Row="1" Style="{StaticResource AppLogTextBoxStyle}" Text="{Binding ExecutionLog, Mode=OneWay}" />
            </Grid>
        </Border>
    </Grid>
</UserControl>
