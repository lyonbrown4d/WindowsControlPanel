<UserControl x:Class="WindowsControlPanel.Views.NetworkDnsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:mvvm="http://prismlibrary.com/"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             mvvm:ViewModelLocator.AutoWireViewModel="True"
             mc:Ignorable="d"
             d:DesignHeight="650"
             d:DesignWidth="900">
    <Grid Margin="{StaticResource AppPageMargin}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="154" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Style="{StaticResource AppEyebrowTextStyle}" Text="NETWORK" />
                <TextBlock Margin="0,5,0,0" Style="{StaticResource AppPageTitleTextStyle}" Text="网络与 DNS" />
                <TextBlock Margin="0,7,0,0"
                           Style="{StaticResource AppBodyTextStyle}"
                           Text="读取当前网络适配器的 IPv4、DNS、DHCP 与网关状态，适合快速排查网络配置。" />
            </StackPanel>
            <WrapPanel Grid.Column="1" Margin="18,0,0,0" VerticalAlignment="Center">
                <ui:Button Width="112" Height="36" Margin="0,0,8,0" Appearance="Primary" Command="{Binding RefreshCommand}" Content="刷新状态" />
                <ui:Button Width="136" Height="36" Appearance="Secondary" Command="{Binding OpenDnsSettingsCommand}" Content="DNS 设置" />
            </WrapPanel>
        </Grid>

        <Border Grid.Row="1"
                Margin="0,0,0,14"
                Padding="14"
                CornerRadius="8"
                Background="{DynamicResource AppSurfaceElevatedBrush}"
                BorderBrush="{DynamicResource AppStrokeBrush}"
                BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Width="34"
                        Height="34"
                        Margin="0,0,12,0"
                        CornerRadius="8"
                        Background="{DynamicResource AppSuccessSoftBrush}"
                        BorderBrush="{DynamicResource AppStrokeBrush}"
                        BorderThickness="1">
                    <ui:SymbolIcon Width="18"
                                   Height="18"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource AppSuccessBrush}"
                                   Symbol="Globe24" />
                </Border>
                <StackPanel Grid.Column="1">
                    <TextBlock FontSize="13" FontWeight="SemiBold" Text="{Binding StatusSummary}" TextWrapping="Wrap" />
                    <TextBlock Margin="0,5,0,0" Style="{StaticResource AppBodyTextStyle}" Text="{Binding HintText}" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="330" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Padding="12"
                    CornerRadius="8"
                    Background="{DynamicResource AppSurfaceBrush}"
                    BorderBrush="{DynamicResource AppStrokeBrush}"
                    BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,0,0,10">
                        <TextBlock Style="{StaticResource AppSectionTitleTextStyle}" Text="网络适配器" />
                        <TextBlock Margin="0,5,0,0"
                                   Style="{StaticResource AppBodyTextStyle}"
                                   Text="默认按在线状态排序，包含物理网卡、虚拟网卡与 VPN。" />
                    </StackPanel>

                    <ListBox Grid.Row="1"
                             ItemsSource="{Binding Adapters}"
                             SelectedItem="{Binding SelectedAdapter, Mode=TwoWay}"
                             ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="10" />
                                <Setter Property="Margin" Value="0,0,0,8" />
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="BorderBrush" Value="{DynamicResource AppStrokeBrush}" />
                                <Setter Property="BorderThickness" Value="1" />
                                <Setter Property="Cursor" Value="Hand" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="{x:Type ListBoxItem}">
                                            <Border x:Name="Root"
                                                    Padding="{TemplateBinding Padding}"
                                                    Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    CornerRadius="8">
                                                <ContentPresenter />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Root" Property="Background" Value="{DynamicResource AppSurfaceElevatedBrush}" />
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="Root" Property="Background" Value="{DynamicResource AppAccentSoftBrush}" />
                                                    <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource AppAccentBrush}" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel>
                                    <TextBlock FontSize="13" FontWeight="SemiBold" Text="{Binding Name}" TextWrapping="Wrap" />
                                    <TextBlock Margin="0,5,0,0" Style="{StaticResource AppBodyTextStyle}" Text="{Binding ListSummary}" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <Border Grid.Column="1"
                    Margin="14,0,0,0"
                    Padding="12"
                    CornerRadius="8"
                    Background="{DynamicResource AppSurfaceBrush}"
                    BorderBrush="{DynamicResource AppStrokeBrush}"
                    BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,0,0,10">
                        <TextBlock Style="{StaticResource AppSectionTitleTextStyle}" Text="适配器详情" />
                        <TextBlock Margin="0,5,0,0"
                                   Style="{StaticResource AppBodyTextStyle}"
                                   Text="以下信息来自系统网络接口 API，仅作诊断和后续模块草案使用。" />
                    </StackPanel>

                    <TextBox Grid.Row="1"
                             Style="{StaticResource AppLogTextBoxStyle}"
                             Text="{Binding SelectedAdapter.DetailText, Mode=OneWay, TargetNullValue=未选择网络适配器。}" />
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="3"
                Margin="0,14,0,0"
                Padding="12"
                CornerRadius="8"
                Background="{DynamicResource AppSurfaceBrush}"
                BorderBrush="{DynamicResource AppStrokeBrush}"
                BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid Grid.Row="0" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Style="{StaticResource AppSectionTitleTextStyle}" Text="日志与提示" />
                    <ui:Button Grid.Column="1" Width="104" Height="32" Appearance="Secondary" Command="{Binding BackToHomeCommand}" Content="返回首页" />
                </Grid>
                <TextBox Grid.Row="1"
                         Style="{StaticResource AppLogTextBoxStyle}"
                         Text="{Binding ExecutionLog, Mode=OneWay}" />
            </Grid>
        </Border>
    </Grid>
</UserControl>
