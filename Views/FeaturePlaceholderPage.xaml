<UserControl x:Class="WindowsControlPanel.Views.FeaturePlaceholderPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:mvvm="http://prismlibrary.com/"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             mvvm:ViewModelLocator.AutoWireViewModel="True"
             mc:Ignorable="d"
             d:DesignHeight="600"
             d:DesignWidth="720">
    <Grid Margin="{StaticResource AppPageMargin}">
        <Border Padding="18"
                CornerRadius="8"
                Background="{StaticResource AppSurfaceBrush}"
                BorderBrush="{StaticResource AppStrokeBrush}"
                BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0">
                    <TextBlock Style="{StaticResource AppEyebrowTextStyle}" Text="MODULE" />
                    <TextBlock Margin="0,5,0,0" Style="{StaticResource AppPageTitleTextStyle}" Text="{Binding Title}" />
                    <TextBlock Margin="0,7,0,0" Style="{StaticResource AppBodyTextStyle}" Text="{Binding Description}" />
                </StackPanel>

                <Border Grid.Row="1"
                        Margin="0,18,0,0"
                        Padding="16"
                        VerticalAlignment="Top"
                        CornerRadius="8"
                        Background="{StaticResource AppSurfaceElevatedBrush}"
                        BorderBrush="{StaticResource AppStrokeBrush}"
                        BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Width="36" Height="36" Margin="0,0,12,0" CornerRadius="9" Background="{StaticResource AppAccentSoftBrush}" BorderBrush="{StaticResource AppStrokeBrush}" BorderThickness="1">
                            <ui:SymbolIcon Width="18" Height="18" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{StaticResource AppAccentBrush}" Symbol="Settings24" />
                        </Border>
                        <StackPanel Grid.Column="1">
                            <TextBlock Style="{StaticResource AppSectionTitleTextStyle}" Text="页面骨架已就绪" />
                            <TextBlock Margin="0,6,0,0" Style="{StaticResource AppBodyTextStyle}" Text="后续可接入脚本执行、状态检测、确认流程和日志回显。" />
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
