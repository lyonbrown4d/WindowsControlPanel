<UserControl x:Class="WindowsControlPanel.Views.GamingAdvancedPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:mvvm="http://prismlibrary.com/"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             mvvm:ViewModelLocator.AutoWireViewModel="True"
             mc:Ignorable="d"
             d:DesignHeight="650"
             d:DesignWidth="900">
    <Grid Margin="{StaticResource AppPageMargin}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="164" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Style="{StaticResource AppEyebrowTextStyle}" Text="GAMING" />
                <TextBlock Margin="0,5,0,0" Style="{StaticResource AppPageTitleTextStyle}" Text="游戏高级工具" />
                <TextBlock Margin="0,7,0,0" Style="{StaticResource AppBodyTextStyle}" Text="整合游戏相关深层设置，并提供一键性能模式。" />
            </StackPanel>
            <ui:Button Grid.Column="1" Width="124" Height="36" Margin="18,0,0,0" VerticalAlignment="Center" Appearance="Secondary" Command="{Binding RefreshStatusCommand}" Content="刷新状态" />
        </Grid>

        <Border Grid.Row="1"
                Margin="0,0,0,14"
                Padding="14"
                CornerRadius="8"
                Background="{DynamicResource AppSurfaceElevatedBrush}"
                BorderBrush="{DynamicResource AppStrokeBrush}"
                BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Width="34" Height="34" Margin="0,0,12,0" CornerRadius="8" Background="{DynamicResource AppSuccessSoftBrush}" BorderBrush="{DynamicResource AppStrokeBrush}" BorderThickness="1">
                    <ui:SymbolIcon Width="18" Height="18" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource AppSuccessBrush}" Symbol="Games24" />
                </Border>
                <StackPanel Grid.Column="1">
                    <TextBlock Style="{StaticResource AppSmallLabelTextStyle}" Text="状态摘要" />
                    <TextBlock Margin="0,5,0,0" FontSize="13" Text="{Binding StatusSummary}" TextWrapping="Wrap" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Margin="0,0,7,0"
                    Padding="14"
                    CornerRadius="8"
                    Background="{DynamicResource AppSurfaceBrush}"
                    BorderBrush="{DynamicResource AppStrokeBrush}"
                    BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0">
                        <TextBlock Style="{StaticResource AppSectionTitleTextStyle}" Text="性能预设" />
                        <TextBlock Margin="0,6,0,0" Style="{StaticResource AppBodyTextStyle}" Text="执行游戏模式脚本，关闭虚拟化链路并偏向性能。" />
                    </StackPanel>
                    <Border Grid.Row="1"
                            Margin="0,14,0,14"
                            Padding="12"
                            CornerRadius="8"
                            Background="{DynamicResource AppDangerSoftBrush}"
                            BorderBrush="{DynamicResource AppStrokeBrush}"
                            BorderThickness="1">
                        <StackPanel>
                            <TextBlock Style="{StaticResource AppSmallLabelTextStyle}" Foreground="{DynamicResource AppDangerBrush}" Text="高风险操作" />
                            <TextBlock Margin="0,6,0,0" Style="{StaticResource AppBodyTextStyle}" Text="该操作可能影响虚拟化、容器和安全特性，执行前会出现确认提示。" />
                        </StackPanel>
                    </Border>
                    <ui:Button Grid.Row="2" Width="150" HorizontalAlignment="Left" Appearance="Danger" Command="{Binding ApplyGamingModeCommand}" Content="应用游戏模式" />
                </Grid>
            </Border>

            <Border Grid.Column="1"
                    Margin="7,0,0,0"
                    Padding="14"
                    CornerRadius="8"
                    Background="{DynamicResource AppSurfaceBrush}"
                    BorderBrush="{DynamicResource AppStrokeBrush}"
                    BorderThickness="1">
                <StackPanel>
                    <TextBlock Style="{StaticResource AppSectionTitleTextStyle}" Text="图形与游戏设置入口" />
                    <TextBlock Margin="0,6,0,14" Style="{StaticResource AppBodyTextStyle}" Text="快速进入 Windows 深层图形、游戏模式和游戏栏设置页面。" />

                    <WrapPanel>
                        <ui:Button Width="170" Margin="0,0,8,8" Appearance="Secondary" Command="{Binding OpenGraphicsSettingsCommand}" Content="打开图形设置" />
                        <ui:Button Width="170" Margin="0,0,8,8" Appearance="Secondary" Command="{Binding OpenGameModeSettingsCommand}" Content="打开游戏模式设置" />
                        <ui:Button Width="170" Margin="0,0,8,8" Appearance="Secondary" Command="{Binding OpenGameBarSettingsCommand}" Content="打开游戏栏设置" />
                    </WrapPanel>
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Row="3"
                Margin="0,14,0,0"
                Padding="12"
                CornerRadius="8"
                Background="{DynamicResource AppSurfaceBrush}"
                BorderBrush="{DynamicResource AppStrokeBrush}"
                BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid Grid.Row="0" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Style="{StaticResource AppSectionTitleTextStyle}" Text="执行日志" />
                    <ui:Button Grid.Column="1" Width="104" Height="32" Appearance="Secondary" Command="{Binding BackToHomeCommand}" Content="返回首页" />
                </Grid>
                <TextBox Grid.Row="1" Style="{StaticResource AppLogTextBoxStyle}" Text="{Binding ExecutionLog, Mode=OneWay}" />
            </Grid>
        </Border>
    </Grid>
</UserControl>
