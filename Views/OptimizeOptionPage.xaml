<UserControl x:Class="WindowsControlPanel.Views.OptimizeOptionPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:mvvm="http://prismlibrary.com/"
             xmlns:regions="http://prismlibrary.com/"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             mvvm:ViewModelLocator.AutoWireViewModel="True"
             mc:Ignorable="d"
             d:DesignHeight="650"
             d:DesignWidth="980">
    <Grid Background="Transparent">
        <Grid.Resources>
            <BooleanToVisibilityConverter x:Key="BoolToVisibility" />

            <Style x:Key="CaptionStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="12" />
                <Setter Property="LineHeight" Value="18" />
                <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
                <Setter Property="TextWrapping" Value="Wrap" />
            </Style>

            <Style x:Key="NavRowButtonStyle" TargetType="Button">
                <Setter Property="MinHeight" Value="64" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                <Setter Property="VerticalContentAlignment" Value="Stretch" />
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderBrush" Value="Transparent" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type Button}">
                            <Border x:Name="Root"
                                    Padding="{TemplateBinding Padding}"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="8"
                                    SnapsToDevicePixels="True">
                                <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Root" Property="Background" Value="{DynamicResource AppButtonHoverBrush}" />
                                    <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource AppStrokeBrush}" />
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Root" Property="Background" Value="{DynamicResource AppButtonPressedBrush}" />
                                    <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource AppAccentBrush}" />
                                </Trigger>
                                <Trigger Property="IsKeyboardFocused" Value="True">
                                    <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource AppAccentBrush}" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="NavDividerStyle" TargetType="Border">
                <Setter Property="Height" Value="1" />
                <Setter Property="Margin" Value="52,0,0,0" />
                <Setter Property="Background" Value="{DynamicResource AppStrokeBrush}" />
                <Setter Property="Opacity" Value="0.55" />
            </Style>

            <Style x:Key="SelectedRailStyle" TargetType="Border">
                <Setter Property="Width" Value="3" />
                <Setter Property="Height" Value="28" />
                <Setter Property="CornerRadius" Value="2" />
                <Setter Property="Background" Value="{DynamicResource AppAccentBrush}" />
                <Setter Property="VerticalAlignment" Value="Center" />
            </Style>
        </Grid.Resources>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="0.32*" MinWidth="292" MaxWidth="340" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Background="{DynamicResource GlassSidebarBrush}"
                BorderBrush="{DynamicResource AppStrokeBrush}"
                BorderThickness="0,0,1,0">
            <Grid Margin="22,22,18,18">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0">
                    <TextBlock Style="{StaticResource AppEyebrowTextStyle}" Text="OPTIMIZE" />
                    <TextBlock Margin="0,4,0,0"
                               FontSize="28"
                               FontWeight="SemiBold"
                               Text="进一步优化" />
                    <TextBlock Margin="0,8,0,0"
                               Style="{StaticResource CaptionStyle}"
                               Text="按任务域进入安全、开发、游戏、启动项、清理和网络控制。" />
                </StackPanel>

                <Border Grid.Row="1"
                        Margin="0,18,0,18"
                        Padding="14,12"
                        CornerRadius="9"
                        Background="{DynamicResource GlassPanelBrush}"
                        BorderBrush="{DynamicResource AppStrokeBrush}"
                        BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Width="9"
                                Height="9"
                                Margin="0,5,12,0"
                                CornerRadius="5"
                                Background="{DynamicResource AppSuccessBrush}" />
                        <StackPanel Grid.Column="1">
                            <TextBlock Style="{StaticResource AppSmallLabelTextStyle}" Text="当前工作区" />
                            <TextBlock Margin="0,5,0,0"
                                       Style="{StaticResource CaptionStyle}"
                                       Text="{Binding GlobalStatus}" />
                        </StackPanel>
                    </Grid>
                </Border>

                <ScrollViewer Grid.Row="2"
                              HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Margin="0,0,0,8" Style="{StaticResource AppSmallLabelTextStyle}" Text="模块" />

                        <Button Style="{StaticResource NavRowButtonStyle}" Command="{Binding OpenSecurityCommand}">
                            <Grid Margin="0,0,0,1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="7" />
                                    <ColumnDefinition Width="44" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Style="{StaticResource SelectedRailStyle}" Visibility="{Binding IsSecuritySelected, Converter={StaticResource BoolToVisibility}}" />
                                <Border Grid.Column="1" Width="32" Height="32" CornerRadius="8" Background="{DynamicResource AppAccentSoftBrush}">
                                    <ui:SymbolIcon Width="18" Height="18" Foreground="{DynamicResource AppAccentBrush}" Symbol="ShieldLock24" />
                                </Border>
                                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                    <TextBlock FontSize="14" FontWeight="SemiBold" Text="安全与虚拟化" />
                                    <TextBlock Margin="0,4,0,0" Style="{StaticResource CaptionStyle}" Text="VBS、Hyper-V、WSL 与沙盒" />
                                </StackPanel>
                                <ui:SymbolIcon Grid.Column="3" Width="16" Height="16" Margin="12,0,8,0" VerticalAlignment="Center" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Symbol="ChevronRight24" />
                            </Grid>
                        </Button>
                        <Border Style="{StaticResource NavDividerStyle}" />

                        <Button Style="{StaticResource NavRowButtonStyle}" Command="{Binding OpenDevelopmentCommand}">
                            <Grid Margin="0,1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="7" />
                                    <ColumnDefinition Width="44" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Style="{StaticResource SelectedRailStyle}" Visibility="{Binding IsDevelopmentSelected, Converter={StaticResource BoolToVisibility}}" />
                                <Border Grid.Column="1" Width="32" Height="32" CornerRadius="8" Background="{DynamicResource GlassPanelElevatedBrush}">
                                    <ui:SymbolIcon Width="18" Height="18" Foreground="{DynamicResource AppAccentBrush}" Symbol="Code24" />
                                </Border>
                                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                    <TextBlock FontSize="14" FontWeight="SemiBold" Text="开发环境" />
                                    <TextBlock Margin="0,4,0,0" Style="{StaticResource CaptionStyle}" Text="开发者模式、终端和工具链" />
                                </StackPanel>
                                <ui:SymbolIcon Grid.Column="3" Width="16" Height="16" Margin="12,0,8,0" VerticalAlignment="Center" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Symbol="ChevronRight24" />
                            </Grid>
                        </Button>
                        <Border Style="{StaticResource NavDividerStyle}" />

                        <Button Style="{StaticResource NavRowButtonStyle}" Command="{Binding OpenGameCommand}">
                            <Grid Margin="0,1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="7" />
                                    <ColumnDefinition Width="44" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Style="{StaticResource SelectedRailStyle}" Visibility="{Binding IsGameSelected, Converter={StaticResource BoolToVisibility}}" />
                                <Border Grid.Column="1" Width="32" Height="32" CornerRadius="8" Background="{DynamicResource GlassPanelElevatedBrush}">
                                    <ui:SymbolIcon Width="18" Height="18" Foreground="{DynamicResource AppAccentBrush}" Symbol="Games24" />
                                </Border>
                                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                    <TextBlock FontSize="14" FontWeight="SemiBold" Text="游戏优化" />
                                    <TextBlock Margin="0,4,0,0" Style="{StaticResource CaptionStyle}" Text="Game Bar、游戏模式和录制" />
                                </StackPanel>
                                <ui:SymbolIcon Grid.Column="3" Width="16" Height="16" Margin="12,0,8,0" VerticalAlignment="Center" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Symbol="ChevronRight24" />
                            </Grid>
                        </Button>
                        <Border Style="{StaticResource NavDividerStyle}" />

                        <Button Style="{StaticResource NavRowButtonStyle}" Command="{Binding OpenStartupCommand}">
                            <Grid Margin="0,1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="7" />
                                    <ColumnDefinition Width="44" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Style="{StaticResource SelectedRailStyle}" Visibility="{Binding IsStartupSelected, Converter={StaticResource BoolToVisibility}}" />
                                <Border Grid.Column="1" Width="32" Height="32" CornerRadius="8" Background="{DynamicResource GlassPanelElevatedBrush}">
                                    <ui:SymbolIcon Width="18" Height="18" Foreground="{DynamicResource AppAccentBrush}" Symbol="Rocket24" />
                                </Border>
                                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                    <TextBlock FontSize="14" FontWeight="SemiBold" Text="启动与服务" />
                                    <TextBlock Margin="0,4,0,0" Style="{StaticResource CaptionStyle}" Text="启动项、服务项和影响级别" />
                                </StackPanel>
                                <ui:SymbolIcon Grid.Column="3" Width="16" Height="16" Margin="12,0,8,0" VerticalAlignment="Center" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Symbol="ChevronRight24" />
                            </Grid>
                        </Button>
                        <Border Style="{StaticResource NavDividerStyle}" />

                        <Button Style="{StaticResource NavRowButtonStyle}" Command="{Binding OpenCleanupCommand}">
                            <Grid Margin="0,1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="7" />
                                    <ColumnDefinition Width="44" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Style="{StaticResource SelectedRailStyle}" Visibility="{Binding IsCleanupSelected, Converter={StaticResource BoolToVisibility}}" />
                                <Border Grid.Column="1" Width="32" Height="32" CornerRadius="8" Background="{DynamicResource GlassPanelElevatedBrush}">
                                    <ui:SymbolIcon Width="18" Height="18" Foreground="{DynamicResource AppAccentBrush}" Symbol="Delete24" />
                                </Border>
                                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                    <TextBlock FontSize="14" FontWeight="SemiBold" Text="磁盘与清理" />
                                    <TextBlock Margin="0,4,0,0" Style="{StaticResource CaptionStyle}" Text="系统维护、缓存和工具箱" />
                                </StackPanel>
                                <ui:SymbolIcon Grid.Column="3" Width="16" Height="16" Margin="12,0,8,0" VerticalAlignment="Center" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Symbol="ChevronRight24" />
                            </Grid>
                        </Button>
                        <Border Style="{StaticResource NavDividerStyle}" />

                        <Button Style="{StaticResource NavRowButtonStyle}" Command="{Binding OpenNetworkCommand}">
                            <Grid Margin="0,1,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="7" />
                                    <ColumnDefinition Width="44" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Style="{StaticResource SelectedRailStyle}" Visibility="{Binding IsNetworkSelected, Converter={StaticResource BoolToVisibility}}" />
                                <Border Grid.Column="1" Width="32" Height="32" CornerRadius="8" Background="{DynamicResource GlassPanelElevatedBrush}">
                                    <ui:SymbolIcon Width="18" Height="18" Foreground="{DynamicResource AppAccentBrush}" Symbol="Globe24" />
                                </Border>
                                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                    <TextBlock FontSize="14" FontWeight="SemiBold" Text="网络与 DNS" />
                                    <TextBlock Margin="0,4,0,0" Style="{StaticResource CaptionStyle}" Text="DNS、网络缓存和连接修复" />
                                </StackPanel>
                                <ui:SymbolIcon Grid.Column="3" Width="16" Height="16" Margin="12,0,8,0" VerticalAlignment="Center" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Symbol="ChevronRight24" />
                            </Grid>
                        </Button>
                    </StackPanel>
                </ScrollViewer>

                <StackPanel Grid.Row="3" Margin="0,18,0,0">
                    <Border Margin="0,0,0,10"
                            Padding="12"
                            CornerRadius="8"
                            Background="{DynamicResource GlassPanelBrush}"
                            BorderBrush="{DynamicResource AppStrokeBrush}"
                            BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Width="26" Height="26" Margin="0,0,10,0" CornerRadius="7" Background="{DynamicResource AppAccentSoftBrush}">
                                <ui:SymbolIcon Width="15" Height="15" Foreground="{DynamicResource AppAccentBrush}" Symbol="Info24" />
                            </Border>
                            <TextBlock Grid.Column="1" Style="{StaticResource CaptionStyle}" Text="高风险操作会先确认；需要管理员权限的动作会明确提示。" />
                        </Grid>
                    </Border>
                    <ui:Button Height="38"
                               Appearance="Secondary"
                               Command="{Binding BackToHomeCommand}"
                               Content="返回首页">
                        <ui:Button.Icon>
                            <ui:SymbolIcon Symbol="Home24" />
                        </ui:Button.Icon>
                    </ui:Button>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Column="1" Margin="18,18,18,18">
            <Border Background="{DynamicResource GlassPanelBrush}"
                    BorderBrush="{DynamicResource AppStrokeBrush}"
                    BorderThickness="1"
                    CornerRadius="10"
                    ClipToBounds="True">
                <ContentControl regions:RegionManager.RegionName="FeatureRegion"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch" />
            </Border>
        </Grid>
    </Grid>
</UserControl>
