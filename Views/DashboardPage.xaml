<UserControl x:Class="WindowsControlPanel.Views.DashboardPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:mvvm="http://prismlibrary.com/"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             mvvm:ViewModelLocator.AutoWireViewModel="True"
             mc:Ignorable="d"
             d:DesignHeight="650"
             d:DesignWidth="980">
    <Grid Margin="24" Background="Transparent">
        <Grid.Resources>
            <Style x:Key="CaptionStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="12" />
                <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
                <Setter Property="TextWrapping" Value="Wrap" />
            </Style>
            <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="18" />
                <Setter Property="FontWeight" Value="SemiBold" />
            </Style>
            <Style x:Key="MetricCardStyle" TargetType="Border">
                <Setter Property="MinHeight" Value="76" />
                <Setter Property="Padding" Value="14" />
                <Setter Property="CornerRadius" Value="8" />
                <Setter Property="Background" Value="{StaticResource AppSurfaceElevatedBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource AppStrokeBrush}" />
                <Setter Property="BorderThickness" Value="1" />
            </Style>
            <Style x:Key="ModuleTileStyle" TargetType="Border">
                <Setter Property="MinHeight" Value="118" />
                <Setter Property="Padding" Value="14" />
                <Setter Property="CornerRadius" Value="8" />
                <Setter Property="Background" Value="{StaticResource AppSurfaceElevatedBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource AppStrokeBrush}" />
                <Setter Property="BorderThickness" Value="1" />
            </Style>
            <Style x:Key="ModuleBodyStyle" TargetType="TextBlock">
                <Setter Property="Margin" Value="0,7,0,0" />
                <Setter Property="FontSize" Value="12" />
                <Setter Property="LineHeight" Value="18" />
                <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
                <Setter Property="TextWrapping" Value="Wrap" />
            </Style>
        </Grid.Resources>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource AppAccentBrush}"
                           Text="CONTROL CENTER" />
                <TextBlock Margin="0,4,0,0"
                           FontSize="28"
                           FontWeight="SemiBold"
                           Text="系统控制台" />
                <TextBlock Margin="0,6,0,0"
                           Style="{StaticResource CaptionStyle}"
                           Text="查看当前系统基线，快速进入虚拟化、启动项、网络和维护工具。" />
            </StackPanel>
            <StackPanel Grid.Column="1"
                        Margin="20,0,0,0"
                        VerticalAlignment="Center"
                        Orientation="Horizontal">
                <Border Width="230"
                        Height="54"
                        Margin="0,0,10,0"
                        Padding="12,7"
                        CornerRadius="8"
                        Background="{StaticResource AppSurfaceElevatedBrush}"
                        BorderBrush="{StaticResource AppStrokeBrush}"
                        BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="112" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock FontSize="12"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       Text="外观主题" />
                            <TextBlock Margin="0,3,0,0"
                                       FontSize="12"
                                       Text="{Binding ThemeSummary}" />
                        </StackPanel>
                        <ComboBox Grid.Column="1"
                                  Height="30"
                                  VerticalAlignment="Center"
                                  ItemsSource="{Binding ThemeOptions}"
                                  DisplayMemberPath="DisplayName"
                                  SelectedValuePath="Value"
                                  SelectedValue="{Binding SelectedThemePreference, Mode=TwoWay}" />
                    </Grid>
                </Border>
                <ui:Button Width="124"
                           Height="36"
                           VerticalAlignment="Center"
                           Appearance="Primary"
                           Command="{Binding RefreshCommand}"
                           Content="刷新状态">
                    <ui:Button.Icon>
                        <ui:SymbolIcon Symbol="ArrowClockwise24" />
                    </ui:Button.Icon>
                </ui:Button>
            </StackPanel>
        </Grid>

        <UniformGrid Grid.Row="1" Columns="4" Margin="0,0,0,18">
            <Border Style="{StaticResource MetricCardStyle}" Margin="0,0,12,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <ui:SymbolIcon Width="20" Height="20" Margin="0,2,12,0" Foreground="{StaticResource AppAccentBrush}" Symbol="PersonKey24" />
                    <StackPanel Grid.Column="1">
                        <TextBlock Style="{StaticResource CaptionStyle}" Text="权限状态" />
                        <TextBlock Margin="0,5,0,0" FontSize="13" FontWeight="SemiBold" Text="{Binding AdministratorStatus}" TextWrapping="Wrap" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border Style="{StaticResource MetricCardStyle}" Margin="0,0,12,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <ui:SymbolIcon Width="20" Height="20" Margin="0,2,12,0" Foreground="{StaticResource AppSuccessBrush}" Symbol="Memory24" />
                    <StackPanel Grid.Column="1">
                        <TextBlock Style="{StaticResource CaptionStyle}" Text="内存" />
                        <TextBlock Margin="0,5,0,0" FontSize="13" FontWeight="SemiBold" Text="{Binding MemoryStatus}" TextWrapping="Wrap" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border Style="{StaticResource MetricCardStyle}" Margin="0,0,12,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <ui:SymbolIcon Width="20" Height="20" Margin="0,2,12,0" Foreground="{StaticResource AppWarningBrush}" Symbol="ShieldLock24" />
                    <StackPanel Grid.Column="1">
                        <TextBlock Style="{StaticResource CaptionStyle}" Text="安全基线" />
                        <TextBlock Margin="0,5,0,0" FontSize="13" FontWeight="SemiBold" Text="{Binding SecuritySummary}" TextWrapping="Wrap" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border Style="{StaticResource MetricCardStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <ui:SymbolIcon Width="20" Height="20" Margin="0,2,12,0" Foreground="{StaticResource AppAccentBrush}" Symbol="Desktop24" />
                    <StackPanel Grid.Column="1">
                        <TextBlock Style="{StaticResource CaptionStyle}" Text="最近刷新" />
                        <TextBlock Margin="0,5,0,0" FontSize="13" FontWeight="SemiBold" Text="{Binding LastRefreshTime}" TextWrapping="Wrap" />
                    </StackPanel>
                </Grid>
            </Border>
        </UniformGrid>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="340" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" Margin="0,0,18,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <ui:Card Grid.Row="0" Padding="16" Margin="0,0,0,14">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="系统概览" />
                        <TextBlock Margin="0,10,0,0" FontSize="13" LineHeight="20" Text="{Binding SystemInfoSummary}" TextWrapping="Wrap" />
                        <Border Height="1" Margin="0,14" Background="{StaticResource AppStrokeBrush}" />
                        <TextBlock Style="{StaticResource CaptionStyle}" Text="虚拟化" />
                        <TextBlock Margin="0,5,0,0" FontSize="13" Text="{Binding VirtualizationSummary}" TextWrapping="Wrap" />
                        <TextBlock Margin="0,12,0,0" Style="{StaticResource CaptionStyle}" Text="性能" />
                        <TextBlock Margin="0,5,0,0" FontSize="13" Text="{Binding PerformanceSummary}" TextWrapping="Wrap" />
                    </StackPanel>
                </ui:Card>

                <ui:Card Grid.Row="1" Padding="16">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="推荐动作" />
                        <TextBlock Margin="0,12,0,0" Style="{StaticResource CaptionStyle}" Text="安全建议" />
                        <TextBlock Margin="0,5,0,0" FontSize="13" LineHeight="20" Text="{Binding SecurityRecommendation}" TextWrapping="Wrap" />
                        <TextBlock Margin="0,14,0,0" Style="{StaticResource CaptionStyle}" Text="性能建议" />
                        <TextBlock Margin="0,5,0,0" FontSize="13" LineHeight="20" Text="{Binding PerformanceRecommendation}" TextWrapping="Wrap" />
                    </StackPanel>
                </ui:Card>
            </Grid>

            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
                <UniformGrid Columns="2">
                    <Border Style="{StaticResource ModuleTileStyle}" Margin="0,0,12,12">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Width="20" Height="20" Margin="0,0,8,0" Foreground="{StaticResource AppWarningBrush}" Symbol="ShieldLock24" />
                                <TextBlock FontSize="16" FontWeight="SemiBold" Text="安全与虚拟化" />
                            </StackPanel>
                            <TextBlock Grid.Row="1" Style="{StaticResource ModuleBodyStyle}" Text="VBS、HVCI、Hyper-V、WSL 和虚拟化平台状态与预设。" />
                            <ui:Button Grid.Row="2" Margin="0,12,0,0" Width="116" HorizontalAlignment="Left" Appearance="Primary" Command="{Binding OpenSecurityCommand}" Content="打开" />
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource ModuleTileStyle}" Margin="0,0,0,12">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Width="20" Height="20" Margin="0,0,8,0" Foreground="{StaticResource AppAccentBrush}" Symbol="Code24" />
                                <TextBlock FontSize="16" FontWeight="SemiBold" Text="开发环境" />
                            </StackPanel>
                            <TextBlock Grid.Row="1" Style="{StaticResource ModuleBodyStyle}" Text="开发者模式、Windows Sudo、winget 清单和容器相关入口。" />
                            <ui:Button Grid.Row="2" Margin="0,12,0,0" Width="116" HorizontalAlignment="Left" Appearance="Secondary" Command="{Binding OpenDevelopmentCommand}" Content="打开" />
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource ModuleTileStyle}" Margin="0,0,12,12">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Width="20" Height="20" Margin="0,0,8,0" Foreground="{StaticResource AppSuccessBrush}" Symbol="Games24" />
                                <TextBlock FontSize="16" FontWeight="SemiBold" Text="游戏优化" />
                            </StackPanel>
                            <TextBlock Grid.Row="1" Style="{StaticResource ModuleBodyStyle}" Text="图形设置、游戏模式和偏性能优先的虚拟化链路切换。" />
                            <ui:Button Grid.Row="2" Margin="0,12,0,0" Width="116" HorizontalAlignment="Left" Appearance="Secondary" Command="{Binding OpenGameCommand}" Content="打开" />
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource ModuleTileStyle}" Margin="0,0,0,12">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Width="20" Height="20" Margin="0,0,8,0" Foreground="{StaticResource AppAccentBrush}" Symbol="Rocket24" />
                                <TextBlock FontSize="16" FontWeight="SemiBold" Text="启动项" />
                            </StackPanel>
                            <TextBlock Grid.Row="1" Style="{StaticResource ModuleBodyStyle}" Text="只读查看 WMI 与注册表启动项来源、命令和作用范围。" />
                            <ui:Button Grid.Row="2" Margin="0,12,0,0" Width="116" HorizontalAlignment="Left" Appearance="Secondary" Command="{Binding OpenStartupCommand}" Content="打开" />
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource ModuleTileStyle}" Margin="0,0,12,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Width="20" Height="20" Margin="0,0,8,0" Foreground="{StaticResource AppWarningBrush}" Symbol="Delete24" />
                                <TextBlock FontSize="16" FontWeight="SemiBold" Text="磁盘与清理" />
                            </StackPanel>
                            <TextBlock Grid.Row="1" Style="{StaticResource ModuleBodyStyle}" Text="存储感知、能耗报告、电池报告和维护入口。" />
                            <ui:Button Grid.Row="2" Margin="0,12,0,0" Width="116" HorizontalAlignment="Left" Appearance="Secondary" Command="{Binding OpenCleanupCommand}" Content="打开" />
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource ModuleTileStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Width="20" Height="20" Margin="0,0,8,0" Foreground="{StaticResource AppSuccessBrush}" Symbol="Globe24" />
                                <TextBlock FontSize="16" FontWeight="SemiBold" Text="网络与 DNS" />
                            </StackPanel>
                            <TextBlock Grid.Row="1" Style="{StaticResource ModuleBodyStyle}" Text="查看适配器、IPv4、DNS、DHCP、网关和连接状态。" />
                            <ui:Button Grid.Row="2" Margin="0,12,0,0" Width="116" HorizontalAlignment="Left" Appearance="Secondary" Command="{Binding OpenNetworkCommand}" Content="打开" />
                        </Grid>
                    </Border>
                </UniformGrid>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
