<UserControl x:Class="WindowsControlPanel.Views.StartupProgramsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:mvvm="http://prismlibrary.com/"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             mvvm:ViewModelLocator.AutoWireViewModel="True"
             mc:Ignorable="d"
             d:DesignHeight="680"
             d:DesignWidth="920">
    <Grid Margin="{StaticResource AppPageMargin}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="164" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Style="{StaticResource AppEyebrowTextStyle}" Text="STARTUP" />
                <TextBlock Margin="0,5,0,0" Style="{StaticResource AppPageTitleTextStyle}" Text="启动项" />
                <TextBlock Margin="0,7,0,0"
                           Style="{StaticResource AppBodyTextStyle}"
                           Text="只读展示 WMI 与常见注册表 Run / RunOnce 启动项，便于定位开机启动来源。" />
            </StackPanel>
            <ui:Button Grid.Column="1"
                       Width="124"
                       Height="36"
                       Margin="18,0,0,0"
                       VerticalAlignment="Center"
                       Appearance="Primary"
                       Command="{Binding RefreshCommand}"
                       Content="刷新列表">
                <ui:Button.Icon>
                    <ui:SymbolIcon Symbol="ArrowClockwise24" />
                </ui:Button.Icon>
            </ui:Button>
        </Grid>

        <Border Grid.Row="1"
                Margin="0,0,0,14"
                Padding="14"
                CornerRadius="8"
                Background="{DynamicResource AppSurfaceElevatedBrush}"
                BorderBrush="{DynamicResource AppStrokeBrush}"
                BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Width="34"
                        Height="34"
                        Margin="0,0,12,0"
                        CornerRadius="8"
                        Background="{DynamicResource AppAccentSoftBrush}"
                        BorderBrush="{DynamicResource AppStrokeBrush}"
                        BorderThickness="1">
                    <ui:SymbolIcon Width="18"
                                   Height="18"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource AppAccentBrush}"
                                   Symbol="Rocket24" />
                </Border>
                <StackPanel Grid.Column="1">
                    <TextBlock Style="{StaticResource AppSmallLabelTextStyle}" Text="启动项摘要" />
                    <TextBlock Margin="0,5,0,0"
                               FontSize="13"
                               Text="{Binding StatusSummary}"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Padding="12"
                CornerRadius="8"
                Background="{DynamicResource AppSurfaceBrush}"
                BorderBrush="{DynamicResource AppStrokeBrush}"
                BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Style="{StaticResource AppSectionTitleTextStyle}" Text="启动项清单" />
                        <Border Margin="10,1,0,0"
                                Padding="8,3"
                                CornerRadius="10"
                                Background="{DynamicResource AppSurfaceElevatedBrush}"
                                BorderBrush="{DynamicResource AppStrokeBrush}"
                                BorderThickness="1">
                            <TextBlock FontSize="11"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       Text="Read only" />
                        </Border>
                    </StackPanel>
                    <TextBlock Grid.Column="1"
                               VerticalAlignment="Center"
                               Style="{StaticResource AppBodyTextStyle}"
                               Text="支持横向滚动查看完整命令" />
                </Grid>

                <DataGrid Grid.Row="1"
                          ItemsSource="{Binding StartupPrograms}"
                          AutoGenerateColumns="False"
                          EnableRowVirtualization="True"
                          EnableColumnVirtualization="True"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto">
                    <DataGrid.Resources>
                        <Style x:Key="WrappedCellText" TargetType="TextBlock">
                            <Setter Property="TextWrapping" Value="Wrap" />
                            <Setter Property="VerticalAlignment" Value="Center" />
                            <Setter Property="LineHeight" Value="17" />
                        </Style>
                    </DataGrid.Resources>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="名称" Width="1.2*" Binding="{Binding Name}" ElementStyle="{StaticResource WrappedCellText}" />
                        <DataGridTextColumn Header="来源" Width="1.1*" Binding="{Binding Source}" ElementStyle="{StaticResource WrappedCellText}" />
                        <DataGridTextColumn Header="位置" Width="1.8*" Binding="{Binding Location}" ElementStyle="{StaticResource WrappedCellText}" />
                        <DataGridTextColumn Header="命令" Width="2.6*" Binding="{Binding Command}" ElementStyle="{StaticResource WrappedCellText}" />
                        <DataGridTextColumn Header="状态摘要" Width="1.4*" Binding="{Binding StatusSummary}" ElementStyle="{StaticResource WrappedCellText}" />
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <Border Grid.Row="3"
                Margin="0,14,0,0"
                Padding="12"
                CornerRadius="8"
                Background="{DynamicResource AppSurfaceBrush}"
                BorderBrush="{DynamicResource AppStrokeBrush}"
                BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid Grid.Row="0" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Style="{StaticResource AppSectionTitleTextStyle}" Text="日志与提示" />
                    <ui:Button Grid.Column="1" Width="104" Height="32" Appearance="Secondary" Command="{Binding BackToHomeCommand}" Content="返回首页" />
                </Grid>
                <TextBox Grid.Row="1"
                         Style="{StaticResource AppLogTextBoxStyle}"
                         Text="{Binding ExecutionLog, Mode=OneWay}" />
            </Grid>
        </Border>
    </Grid>
</UserControl>
